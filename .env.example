# Mezathane.tr — ortam değişkenleri örneği
#
# Bu dosya SADECE değişken adlarını gösterir; gerçek değerler/anahtarlar burada
# OLMAMALI (asıl .env dosyası .gitignore ile gizli tutulur, GitHub'a gönderilmez).
# Yeni bir kurulumda bu listeyi rehber alıp değerleri Vercel'e (veya yerel .env'e) girin.

# --- Veritabanı (Neon Postgres) ---
DATABASE_URL=

# --- Kimlik doğrulama (NextAuth) ---
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# Hassas alanları şifrelemek için (64 hex karakter). Bkz. lib/encryption.ts
ENCRYPTION_KEY=

# --- Dosya depolama (Cloudflare R2) ---
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Herkese açık dosya adresi (özel alan adı): https://dosyalar.mezathane.tr
R2_PUBLIC_URL=
# Ana (herkese açık) bucket adı — görseller/dokümanlar
AWS_BUCKET_NAME=
# Ayrı, GİZLİ yedek bucket'ı — gece veritabanı yedekleri buraya yazılır
R2_BACKUP_BUCKET_NAME=

# --- E-posta gönderimi (Zoho Mail SMTP) ---
ZOHO_SMTP_USER=
ZOHO_SMTP_PASSWORD=

# --- Canlı müzayede anlık güncelleme (Ably) ---
# Sunucu tarafı tam yetkili anahtar
ABLY_API_KEY=
# İstemci (tarayıcı) tarafı yalnızca-dinleme anahtarı — herkese açık, gizli değil
NEXT_PUBLIC_ABLY_KEY=

# --- Zamanlanmış görevler (cron-job.org) ---
# Hatırlatma/cron endpoint'lerini doğrulamak için rastgele üretilmiş gizli anahtar
CRON_SECRET=

# --- Hata takibi (Sentry) ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# --- Arama motoru indekslemesi ---
# Yalnızca "true" olduğunda site Google'a açılır. Ayarlı değilse tüm site noindex.
# 🔴 GERÇEK AÇILIŞTA (demo veriler temizlenince) "true" yapılmalı.
NEXT_PUBLIC_ALLOW_INDEXING=

# --- Analitik (opsiyonel, Google Analytics) ---
NEXT_PUBLIC_GA_MEASUREMENT_ID=
